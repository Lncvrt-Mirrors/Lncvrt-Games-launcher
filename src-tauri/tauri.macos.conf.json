{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lncvrt Games Launcher",
  "version": "1.9.1",
  "identifier": "xyz.lncvrt.games-launcher",
  "build": {
    "beforeDevCommand": "next dev --webpack",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "next build",
    "frontendDist": "../out"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Lncvrt Games Launcher",
        "url": "/update/checking",
        "width": 1000,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Game",
    "shortDescription": "A launcher for downloading, managing, and launching games with built-in mod support.",
    "longDescription": "Lncvrt Games Launcher lets you download and manage multiple versions of games, install mods, and launch them directly. Linux users can run Windows exclusive games via Wine (or proton via a custom command).",
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.icns"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFODI3MTAwQkNBMjE4REEKUldUYUdLSzhBSEdDM3J0N1NvbENsdDQ3c3BOdWlFajErVnlLZitSc2l5WVI0VjQ1ZHNMWjYzaUwK",
      "endpoints": [
        "https://games.lncvrt.xyz/api/launcher/update?target={{target}}&arch={{arch}}&currentVersion={{current_version}}"
      ]
    }
  }
}
