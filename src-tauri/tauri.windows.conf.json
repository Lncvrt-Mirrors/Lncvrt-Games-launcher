{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lncvrt Games Launcher",
  "version": "1.9.0",
  "identifier": "xyz.lncvrt.games-launcher",
  "build": {
    "beforeDevCommand": "next dev --webpack",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "next build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lncvrt Games Launcher",
        "url": "/update/checking",
        "width": 1000,
        "height": 632,
        "minWidth": 900,
        "minHeight": 532,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFODI3MTAwQkNBMjE4REEKUldUYUdLSzhBSEdDM3J0N1NvbENsdDQ3c3BOdWlFajErVnlLZitSc2l5WVI0VjQ1ZHNMWjYzaUwK",
      "endpoints": [
        "https://games.lncvrt.xyz/api/launcher/update?target={{target}}&arch={{arch}}&currentVersion={{current_version}}"
      ]
    }
  }
}
