{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "os:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-request-user-attention",
    "fs:default",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "store:default",
    "store:allow-load",
    "store:allow-save",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://games.lncvrt.xyz/api/launcher/latest" },
        { "url": "https://games.lncvrt.xyz/api/launcher/versions" },
        { "url": "https://games.lncvrt.xyz/api/launcher/download" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/account" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/leaderboard/score" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/leaderboard/berry" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/leaderboard/coin" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/leaderboard/legacy" },
        { "url": "https://games.lncvrt.xyz/api/berrydash/leaderboard/total" },
        { "url": "https://games.lncvrt.xyz/api/launcher/mods" }
      ]
    }
  ]
}
